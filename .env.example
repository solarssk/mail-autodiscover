APP_NAME=mail-autodiscover
APP_ENV=production

# GHCR image tag for docker-compose.ghcr.yml (defaults to latest when unset)
# IMAGE_TAG=0.2.0

PUBLIC_BASE_URL=https://autodiscover.example.com

ALLOWED_DOMAINS=example.com

MAIL_DISPLAY_NAME=Example Mail
MAIL_DISPLAY_SHORT_NAME=Example

IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_SOCKET_TYPE=SSL
IMAP_AUTHENTICATION=password-cleartext

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SOCKET_TYPE=STARTTLS
SMTP_AUTHENTICATION=password-cleartext

USERNAME_FORMAT=email

HOST_PORT=8088
CONTAINER_PORT=8000

TRUST_PROXY_HEADERS=true
# IPs/CIDRs of your reverse proxy or Docker bridge that may set X-Forwarded-For / X-Real-IP.
# Set per deployment (see README). Empty = legacy: trust any peer when TRUST_PROXY_HEADERS=true.
# TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.0/8
TRUSTED_PROXY_IPS=
ACCESS_LOG_SKIP_PATHS=/health,/favicon.ico,/apple-touch-icon.png
LOG_LEVEL=INFO

MAX_REQUEST_BODY_BYTES=16384

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

SECURITY_HEADERS_ENABLED=true

OUTLOOK_ENABLED=true
THUNDERBIRD_ENABLED=true
APPLE_MOBILECONFIG_ENABLED=true

POP3_ENABLED=false
POP3_HOST=mail.example.com
POP3_PORT=995
POP3_SOCKET_TYPE=SSL
POP3_AUTHENTICATION=password-cleartext

RETURN_404_FOR_UNKNOWN_DOMAIN=true
DISABLE_ACCESS_LOG=false
